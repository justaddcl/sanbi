{
  "name": "sanbi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "build": "next build",
    "db:start": "turbo run db:studio",
    "db:start:raw": "open -a Docker && sleep 1 && ./start-database.sh && pnpm db:studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:push:preview": "SANBI_APP_ENV=preview drizzle-kit push",
    "db:push:prod": "SANBI_APP_ENV=production drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "dotenvx run -- npx tsx ./src/server/db/seed.ts",
    "db:e2e:push": "dotenvx run -f .env.e2e -- drizzle-kit push",
    "db:e2e:seed": "dotenvx run -f .env.e2e -- npx tsx ./src/server/db/seed-e2e.ts",
    "db:seed:preview": "SANBI_APP_ENV=preview dotenvx run -- npx tsx ./src/server/db/seed.ts",
    "db:seed:prod": "SANBI_APP_ENV=production dotenvx run -- npx tsx ./src/server/db/seed.ts",
    "db:clear": "dotenvx run -- npx tsx ./src/server/db/clear.ts",
    "db:clear:preview": "SANBI_APP_ENV=preview dotenvx run -- npx tsx ./src/server/db/clear.ts",
    "db:clear:prod": "SANBI_APP_ENV=production dotenvx run -- npx tsx ./src/server/db/clear.ts",
    "db:update": "dotenvx run -- npx tsx ./src/server/db/clear.ts && drizzle-kit push && dotenvx run -- npx tsx ./src/server/db/seed.ts",
    "db:update:preview": "SANBI_APP_ENV=preview dotenvx run -- npx tsx ./src/server/db/clear.ts && SANBI_APP_ENV=preview drizzle-kit push && SANBI_APP_ENV=preview dotenvx run -- npx tsx ./src/server/db/seed.ts",
    "db:update:prod": "SANBI_APP_ENV=production dotenvx run -- npx tsx ./src/server/db/clear.ts && SANBI_APP_ENV=production drizzle-kit push && SANBI_APP_ENV=production dotenvx run -- npx tsx ./src/server/db/seed.ts",
    "dev": "NODE_ENV=development next dev | pino-pretty --colorize --translateTime 'SYS:standard' --ignore 'pid,hostname'",
    "dev:turbo": "turbo dev",
    "docker:daemon": "tsx ./src/scripts/start-docker.ts",
    "docker:wait": "tsx ./src/scripts/wait-for-docker.ts",
    "db:up": "./start-database.sh",
    "lint:next": "eslint .",
    "start": "next start",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic",
    "test": "jest",
    "test:e2e": "dotenvx run -f .env.e2e -- playwright test",
    "test:e2e:ci": "playwright test",
    "test:e2e:reuse": "PLAYWRIGHT_SKIP_WEB_SERVER=1 dotenvx run -f .env.e2e -- playwright test",
    "test:watch": "jest --watch",
    "lint": "eslint . && tsc --noEmit --project tsconfig.json",
    "type-check": "tsc --noEmit --project tsconfig.json",
    "test:jest": "jest"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.4.1",
