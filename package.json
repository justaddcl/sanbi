    "postgres": "^3.4.9",
    "punycode": "^2.3.1",
    "react": "^19.2.6",
    "react-day-picker": "10.0.1",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "server-only": "^0.0.1",
    "sonner": "^2.0.7",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "usehooks-ts": "^3.1.1",
    "uuid": "^14.0.0",
